    {
      "parameters": {
        "jsCode": "if (!$json || Object.keys($json).length === 0) {\n  return [ [], [{ json: { status: 'processing', info: 'Not tracked yet' } }] ];\n}\nreturn [ [{ json: { ...$json, status: 'checking', request_id: $json.requestId } }], [] ];"
