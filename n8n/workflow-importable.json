    {
      "parameters": {
        "jsCode": "const ready = $(\"V13 - Is Ready?\").first().json;\nconst target = ready.targetGroup || [];\n\nconst getItemsFromNode = (nodeName) => {\n  const all = $(nodeName).all();\n  if (all.length === 0) return [];\n  if (all.length === 1 && Array.isArray(all[0].json)) return all[0].json;\n  return all.map(i => i.json);\n};\n\nconst itemsL = getItemsFromNode(\"V13 - Bajar L\");\nconst itemsC = getItemsFromNode(\"V13 - Bajar C\");\n\nconst norm = (u) => String(u || '').toLowerCase().replace(/[@.\\s]/g, '').trim();\nconst targetNorm = target.map(u => norm(u));\n\nconst extractUsername = (i) => {\n  return i.username || i.userName || i.ownerUsername || i.user?.username || i.owner?.username || '';\n};\n\nconst foundNamesL = itemsL.map(i => norm(extractUsername(i))).filter(n => n.length > 0);\nconst foundNamesC = itemsC.map(i => norm(extractUsername(i) || i.text?.match(/@(\\w+)/)?.[1] || '')).filter(n => n.length > 0);\n\nreturn [{\n  json: {\n    status: 'done', \n    request_id: ready.request_id,\n    likes: target.filter((u, i) => foundNamesL.includes(targetNorm[i])),\n    comments: target.filter((u, i) => foundNamesC.includes(targetNorm[i])),\n    reposts: [],\n    debug: {\n       l: itemsL.length,\n       c: itemsC.length\n    }\n  }\n}];"
      },
