    {
      "parameters": {
        "jsCode": "const likes = $(\"V13 - Status L\").first().json;\nconst comments = $(\"V13 - Status C\").first().json;\nconst mapping = $(\"V14 - Mapper\").first().json;\n\nconst lStatus = (likes.status || likes.data?.status || '').toUpperCase();\nconst cStatus = (comments.status || comments.data?.status || '').toUpperCase();\n\nif (lStatus !== 'SUCCEEDED' || cStatus !== 'SUCCEEDED') {\n  return [ [null], [{ json: {\n    status: 'processing',\n    request_id: mapping.request_id,\n    info: `Likes: ${lStatus}, Comments: ${cStatus}`\n  } }] ];\n}\n\nreturn [ [{ json: { \n    status: 'ready', \n    likesDatasetId: likes.defaultDatasetId || likes.data?.defaultDatasetId, \n    commentsDatasetId: comments.defaultDatasetId || comments.data?.defaultDatasetId,\n    targetGroup: mapping.targetGroup,\n    request_id: mapping.request_id\n} }], [null] ];"
      },
